# ===== حل مشاكل التبعيات =====
legacy-peer-deps=true
strict-peer-dependencies=false

# ===== تثبيت الإصدارات الدقيقة =====
save-exact=true

# ===== تحسين الأداء =====
fund=false
audit=false

# ===== استخدام registry موثوق =====
registry=https://registry.npmjs.org/

# ===== تعطيل رسائل التثبيت المزعجة =====
loglevel=error

# ===== إصلاح مشكلة vite =====
@vitejs/plugin-vue:legacy-peer-deps=true